# ── backup.conf ───────────────────────────────────────────────
# Shared config for backup.sh and run.sh
# Edit this file — do not hardcode paths in the scripts.
# ──────────────────────────────────────────────────────────────

# Destination drive mount point
# Set this to wherever your backup drive is mounted (local or remote path).
# Example: DEST_ROOT="/Volumes/SanDisk"
DEST_ROOT=""

# SSH remote host (optional)
# If set, rsync over SSH to this host instead of a local mount.
# DEST_ROOT is then the path on the remote machine.
# Example: REMOTE_HOST="mrizzo@黒死神.local"
REMOTE_HOST=""

# Name used for the backup folder: $DEST_ROOT/Backup/<BACKUP_NAME>
# Useful when hostname returns "Mac" (macOS default) or changes after an update.
# Leave blank to use the machine's hostname automatically.
# Example: BACKUP_NAME="old-macbook"
BACKUP_NAME=""

# Sources to back up
SOURCES=(
  "$HOME/Documents"
  "$HOME/Desktop"
  "$HOME/Pictures"
  "$HOME/Downloads"
  "$HOME/.ssh"
  "$HOME/.zshrc"
  "$HOME/.gitconfig"
  "$HOME/.zsh_history"
)

# Files and directories to exclude from backup
# Supports rsync wildcard patterns:
#   *.dmg        — exclude by extension, anywhere in the tree
#   node_modules/ — exclude a directory by name (trailing slash = dir only)
#   .Trash/      — exclude a specific named directory
EXCLUDES=(
  # macOS clutter
  '.DS_Store'
  'Thumbs.db'
  '.localized'
  '.Trash/'

  # Temp and build files
  '*.tmp'
  '*.pyc'
  '__pycache__/'
  'node_modules/'

  # Large files you probably don't want on the backup drive
  # Uncomment or add your own:
  # '*.dmg'
  # '*.iso'
  # '*.vmdk'
  # 'Virtual Machines.localized/'

  # Photos.app — exclude internal databases/caches that churn constantly
  'Photos Library.photoslibrary/database/'
  'Photos Library.photoslibrary/internal/'
  'Photos Library.photoslibrary/private/'
  'Photos Library.photoslibrary/resources/'
  'Photos Library.photoslibrary/scopes/'
  'Photos Library.photoslibrary/iPod Photo Cache/'
)
